{
  "name": "pi-lynx",
  "version": "1.0.0",
  "description": "Pi extension for web search and fetch via lynx + DuckDuckGo Lite. Zero API keys.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "pi-lynx contributors",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "web-search",
    "lynx",
    "duckduckgo"
  ],
  "scripts": {
    "test": "npx tsx index.test.ts",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit --strict --skipLibCheck index.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typebox": "^1.3.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "files": [
    "index.ts",
    "test/fixtures/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": ["./index.ts"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dabito/pi-lynx"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
