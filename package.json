{
  "name": "pi-lynx",
  "version": "1.0.6",
  "description": "Pi extension for plain-text web search and page fetch via lynx + DuckDuckGo Lite. Body text first, links opt-in, no API keys.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "pi-lynx contributors",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "agent-tool",
    "web-search",
    "web-fetch",
    "page-fetch",
    "plain-text",
    "context-safe",
    "terminal-browser",
    "text-browser",
    "duckduckgo",
    "duckduckgo-lite",
    "lynx",
    "no-api-keys",
    "no-account"
  ],
  "scripts": {
    "test": "npx tsx index.test.ts && npx tsx tool-contract.test.ts",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit --strict --skipLibCheck",
    "lint": "eslint ."
  },
  "dependencies": {
    "typebox": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "files": [
    "index.ts",
    "core.ts",
    "runtime.ts",
    "tool-contract.test.ts",
    "test/fixtures/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dabito/pi-lynx.git"
  },
  "bugs": {
    "url": "https://github.com/dabito/pi-lynx/issues"
  },
  "homepage": "https://github.com/dabito/pi-lynx#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
