[0.000, "o", "                                                                               \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   std                                                                                           \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245mModule async_iter  (BUTTON) Copy item path                                                       \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   Source                                                                                        \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   üî¨This is a nightly-only experimental API. (async_iterator #79024)                            \u001b[49m\u001b[0m\u001b]8;"]
[0.000, "o", ";\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   Expand description                                                                            \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   Composable asynchronous iteration.                                                            \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   If you‚Äôve found yourself with an asynchronous collection of some kind,                        \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   and needed to perform an operation on the elements of said collection,                        \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   you‚Äôll quickly run into ‚Äòasync iterators"]
[0.000, "o", "‚Äô. Async Iterators are heavily                        \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   used in idiomatic asynchronous Rust code, so it‚Äôs worth becoming                              \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   familiar with them.                                                                           \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   Before explaining more, let‚Äôs talk about how this module is structured:                       \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m¬ßOrganization                                                                                    \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;4"]
[0.000, "o", "6;66m \u001b[38;2;192;202;245m                                                                                                 \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m   This module is largely organized by type:                                                     \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m     * Traits are the core portion: these traits define what kind of                             \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m       async iterators exist and what you can do with them. The methods of                       \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m       these traits are worth putting some extra study time into.                                \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m     * Functions provide some helpful ways to create some basic async                            \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[48;2;41;46;66m \u001b[38;2;192;202;245m                                                                     "]
